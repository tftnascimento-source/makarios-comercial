# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Force these to always be LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.sh   text eol=lf

# Binaries
*.png  binary
*.jpg  binary
*.pdf  binary
*.xlsx binary
